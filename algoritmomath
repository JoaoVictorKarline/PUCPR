# Funções calcular proposições e retornar array
def calcular_and(prop1, prop2):
    vetor_and = []
    i = 0
    tam = len(prop1)
    while i < tam:
        if prop1[i] == 1 and prop2[i] == 1:
            vetor_and.append(1)
        else:
            vetor_and.append(0)
        i += 1
    return vetor_and


def calcular_or(prop1, prop2):
    vetor_or = []
    i = 0
    tam = len(prop1)
    while i < tam:
        if prop1[i] == 0 and prop2[i] == 0:
            vetor_or.append(0)
        else:
            vetor_or.append(1)
        i += 1
    return vetor_or


def calcular_implicacao(prop1, prop2):
    vetor_impicacao = []
    i = 0
    tam = len(prop1)
    while i < tam:
        if prop1[i] == 1 and prop2[i] == 0:
            vetor_impicacao.append(0)
        else:
            vetor_impicacao.append(1)
        i += 1
    return vetor_impicacao


def calcular_bicondicional(prop1, prop2):
    vetor_bicondicional = []
    i = 0
    tam = len(prop1)
    while i < tam:
        if prop1[i] == prop2[i]:
            vetor_bicondicional.append(1)
        else:
            vetor_bicondicional.append(0)
        i += 1
    return vetor_bicondicional

