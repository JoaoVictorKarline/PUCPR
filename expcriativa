void telaBase() {
  fill(branco);
  stroke(#000000);
  strokeWeight(4);
  rect(30, 30, 1140, 740, 90);
}

void linhas(float x, color cor) {
  stroke(cor);
  strokeWeight(50);
  line(x-400, height, x-100, 0);
  line(x-300, height, x, 0);
  line(x-200, height, x+100, 0);
  line(x-100, height, x+200, 0);
  line(x, height, x+300, 0);
  line(x+100, height, x+400, 0);
  line(x+200, height, x+500, 0);
  line(x+300, height, x+600, 0);
  line(x+400, height, x+700, 0);
  line(x+500, height, x+800, 0);
  line(x+600, height, x+900, 0);
  line(x+700, height, x+1000, 0);
  line(x+800, height, x+1100, 0);
  line(x+900, height, x+1200, 0);
  line(x+1000, height, x+1300, 0);
  line(x+1100, height, x+1400, 0);
}
