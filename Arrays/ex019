vet = [1, 2, 3, 0, 0, 1, 0, 0, 0]

count = 0
maior = 0

for i in range(0, len(vet)):
    if vet[i] == 0:
        count = 0
        for j in range(i, len(vet)):
            if vet[j] == 0:
                count += 1
            else:
                break
    if count > maior:
        maior = count

print(f"A maior sequência é {maior}")
