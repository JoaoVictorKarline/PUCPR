import pickle
import os

if os.path.exists("cliente.pkl"):
    with open("cliente.pkl", "rb") as arquivo:
        objeto = pickle.load(arquivo)
else:

    objeto = {
        "nome": "",
        "saldo": 0.0,
        "historico_transacoes": []
    }

senha_gerente = "Admin@123"

while True:
    print("-- MENU PRINCIPAL --")
    print("1 - Cliente")
    print("2 - Gerente")
    print("3 - Salvar transações")
    print("4 - Sair")

    op = int(input(": "))

    if op == 4:
        with open("cliente.pkl", "wb") as arquivo:
            pickle.dump(objeto, arquivo)
        print("Dados salvos.")
        break

    elif op == 1:
        if objeto["nome"] == "":
            print("Nenhum cliente cadastrado. Acesse o menu do gerente primeiro.")
        else:
            print(f"SEJA BEM VINDO {objeto['nome']}")
            while True:
                print("1 - Consultar saldo")
                print("2 - Depositar valor")
                print("3 - Sacar valor")
                print("4 - Simular rendimento")
                print("5 - Listar últimas transações (extrato)")
                print("6 - Menu Principal")

                op = int(input(": "))

                if op == 6:
                    break

                elif op == 1:
                    print(f"Seu saldo é de: {objeto['saldo']}")

                elif op == 2:
                    valor_deposito = float(input("Digite o valor do depósito: R$ "))
                    objeto['saldo'] += valor_deposito
                    print(f"Seu novo saldo é de {objeto['saldo']}")
                    objeto['historico_transacoes'].append(valor_deposito)

                elif op == 3:
                    valor_sacado = float(input("Digite o valor para ser sacado: R$ "))
                    if valor_sacado > objeto['saldo']:
                        print("Saldo insuficiente.")
                    else:
                        objeto['saldo'] -= valor_sacado
                        print(f"Seu novo saldo é de {objeto['saldo']}")
                        objeto['historico_transacoes'].append(-valor_sacado)

                elif op == 4:
                    print("-- SIMULAÇÃO EM 12 MESES --")
                    saldo_novo = objeto['saldo']
                    for i in range(0, 12):
                        saldo_novo *= 1.011
                        print(f"Mês {i+1}: {saldo_novo:.2f}")
                    print(f"\nRendimento total: R$ {saldo_novo - objeto['saldo']:.2f}\n")

                elif op == 5:
                    print("-- EXTRATO --")
                    for transacao in objeto['historico_transacoes']:
                        if transacao > 0:
                            print(f"Depósito: +R$ {transacao}")
                        else:
                            print(f"Saque: R$ {transacao}")

    elif op == 2:
        # Autenticação Gerente (Validação da senha, limite 3 tentativas)

        tentativas = 3
        autenticado = False
        while tentativas > 0:
            senha_digitada = input("Digite sua senha: ")
            if senha_digitada == senha_gerente:
                autenticado = True
                break

            else:
                print("Senha incorreta!")
                tentativas -= 1

        if tentativas == 0:
            print("Número máximo de tentativas atingidas.")

        if autenticado:
            print("-- BEM VINDO! --")
            while True:
                print("1 - Cadastrar ou alterar o nome do cliente")
                print("2 - Corrigir Saldo")
                print("3 - Consultar dados do cliente")
                print("4 - Listar últimas transações")
                print("5 - Menu Principal")

                op = int(input(": "))

                if op == 5:
                    break

                elif op == 1:
                    # Cadastra e cria um novo arquivo .pkl
                    objeto["nome"] = input("Digite o nome do cliente: ")
                    print(f"Nome atualizado para: {objeto['nome']}")

                elif op == 2:
                    objeto["saldo"] = float(input("Digite o saldo atualizado do cliente: "))
                    print(f"Saldo atualizado para: R$ {objeto['saldo']:.2f}")

                elif op == 3:
                    print("-- DADOS DO CLIENTE --")
                    print(f"Nome:  {objeto['nome']}")
                    print(f"Saldo: R$ {objeto['saldo']:.2f}")
                    print(f"Transações registradas: {len(objeto['historico_transacoes'])}")

                elif op == 4:
                    for transacao in objeto['historico_transacoes']:
                        if transacao > 0:
                            print(f"Depósito: +R$ {transacao}")
                        else:
                            print(f"Saque: R$ {transacao}")

    elif op == 3:
        with open("cliente.pkl", "wb") as arquivo:
            pickle.dump(objeto, arquivo)
        print("Dados salvos com sucesso!")
    else:
        print("Opção invalida!")
