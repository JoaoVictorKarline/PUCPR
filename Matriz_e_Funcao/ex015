def ordena(vet):
    for i in range(0, len(vet)):
        for j in range(i+1, len(vet)):
            if vet[j] < vet[i]:
                aux = vet[i]
                vet[i] = vet[j]
                vet[j] = aux
    return vet

vetor = [5, 10, 15, 33, 1, 4, 2, 3, 100, 0]
vetor_ordenado = ordena(vetor)
print(vetor_ordenado)
